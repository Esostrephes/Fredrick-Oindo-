<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Happy Mother's Day 💛</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Dancing+Script:wght@600;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --amber:    #F4A827;
      --coral:    #F26D5B;
      --blush:    #F5B8A0;
      --rose:     #E8607A;
      --marigold: #F7C948;
      --cream:    #FFF8EF;
      --warm-brown: #7A3B2E;
      --soft-tan:  #F2DCC8;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      font-family: 'Cormorant Garamond', serif;
      overflow-x: hidden;
      min-height: 100vh;
      position: relative;
    }

    /* ── Animated gradient background ── */
    .bg-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      background: radial-gradient(ellipse at 20% 30%, #FDDFA066 0%, transparent 55%),
                  radial-gradient(ellipse at 80% 70%, #F5B8A055 0%, transparent 55%),
                  radial-gradient(ellipse at 50% 10%, #F26D5B33 0%, transparent 50%),
                  var(--cream);
      animation: bgShift 12s ease-in-out infinite alternate;
    }
    @keyframes bgShift {
      0%   { filter: hue-rotate(0deg) brightness(1); }
      50%  { filter: hue-rotate(10deg) brightness(1.03); }
      100% { filter: hue-rotate(-8deg) brightness(0.98); }
    }

    /* ── Floating petals ── */
    .petals-layer {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      overflow: hidden;
    }
    .petal {
      position: absolute;
      top: -60px;
      width: 18px; height: 26px;
      border-radius: 50% 0 50% 0;
      opacity: 0;
      animation: fall linear infinite;
    }
    @keyframes fall {
      0%   { transform: translateY(-60px) rotate(0deg) scale(0.8); opacity: 0; }
      10%  { opacity: 0.75; }
      85%  { opacity: 0.6; }
      100% { transform: translateY(110vh) rotate(540deg) scale(1.1); opacity: 0; }
    }

    /* ── Main wrapper ── */
    .page {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 60px 20px 100px;
      gap: 0;
    }

    /* ── Hero section ── */
    .hero {
      text-align: center;
      max-width: 700px;
      padding: 0 20px;
    }

    .tag-line {
      font-family: 'Dancing Script', cursive;
      font-size: clamp(1rem, 3vw, 1.4rem);
      color: var(--coral);
      letter-spacing: 0.08em;
      opacity: 0;
      animation: rise 1s ease forwards 0.3s;
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 9vw, 6rem);
      font-weight: 700;
      line-height: 1.05;
      color: var(--warm-brown);
      margin: 12px 0 0;
      opacity: 0;
      animation: rise 1s ease forwards 0.6s;
    }
    .hero-title .accent {
      font-style: italic;
      color: var(--rose);
    }

    .hero-sub {
      font-size: clamp(1.1rem, 2.5vw, 1.45rem);
      color: #a05540;
      font-weight: 300;
      margin-top: 18px;
      line-height: 1.6;
      opacity: 0;
      animation: rise 1s ease forwards 0.9s;
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Divider ── */
    .divider {
      width: 120px; height: 3px;
      margin: 36px auto;
      background: linear-gradient(90deg, transparent, var(--amber), var(--coral), var(--amber), transparent);
      border-radius: 2px;
      opacity: 0;
      animation: rise 1s ease forwards 1.1s;
    }

    /* ── Message card ── */
    .card {
      background: rgba(255,255,255,0.72);
      backdrop-filter: blur(14px);
      border: 1.5px solid rgba(244,168,39,0.28);
      border-radius: 28px;
      padding: clamp(32px, 6vw, 56px) clamp(28px, 7vw, 64px);
      max-width: 680px;
      width: 100%;
      box-shadow: 0 8px 48px rgba(242,109,91,0.13), 0 2px 12px rgba(0,0,0,0.06);
      opacity: 0;
      animation: rise 1.1s ease forwards 1.3s;
      position: relative;
      overflow: hidden;
    }
    .card::before {
      content: '"';
      position: absolute;
      top: -10px; left: 16px;
      font-family: 'Playfair Display', serif;
      font-size: 160px;
      color: var(--marigold);
      opacity: 0.12;
      line-height: 1;
      pointer-events: none;
    }

    .message {
      font-size: clamp(1.05rem, 2.2vw, 1.28rem);
      line-height: 1.9;
      color: #5a2e22;
      font-weight: 300;
      font-style: italic;
      position: relative;
      z-index: 1;
    }
    .message strong {
      font-weight: 600;
      font-style: normal;
      color: var(--rose);
    }

    .signature {
      margin-top: 28px;
      text-align: right;
      font-family: 'Dancing Script', cursive;
      font-size: clamp(1.2rem, 3vw, 1.6rem);
      color: var(--warm-brown);
    }

    /* ── Animated hearts row ── */
    .hearts-row {
      display: flex;
      gap: 18px;
      justify-content: center;
      margin: 44px 0 0;
      flex-wrap: wrap;
      opacity: 0;
      animation: rise 1s ease forwards 1.7s;
    }
    .heart-bubble {
      width: 64px; height: 64px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px;
      animation: pulse 3s ease-in-out infinite;
      cursor: default;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    .heart-bubble:nth-child(1) { background: #FDE8D0; animation-delay: 0s; }
    .heart-bubble:nth-child(2) { background: #FCDCD7; animation-delay: 0.4s; }
    .heart-bubble:nth-child(3) { background: #FFF0C4; animation-delay: 0.8s; }
    .heart-bubble:nth-child(4) { background: #F9D6CB; animation-delay: 1.2s; }
    .heart-bubble:nth-child(5) { background: #F5E4F5; animation-delay: 1.6s; }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50%       { transform: scale(1.15); }
    }

    /* ── Qualities strip ── */
    .qualities {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
      max-width: 700px;
      margin-top: 44px;
      opacity: 0;
      animation: rise 1s ease forwards 2s;
    }
    .qual-chip {
      padding: 10px 22px;
      border-radius: 50px;
      font-size: 0.92rem;
      font-family: 'Cormorant Garamond', serif;
      font-weight: 400;
      letter-spacing: 0.04em;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      cursor: default;
    }
    .qual-chip:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
    .q1 { background: #FDE8D0; color: #8B3A2A; }
    .q2 { background: #FCDCD7; color: #7A2338; }
    .q3 { background: #FFF0C4; color: #7A5A00; }
    .q4 { background: #F9D6CB; color: #7A2930; }
    .q5 { background: #F5E4F5; color: #5C2C6E; }
    .q6 { background: #D4EDE1; color: #1B5E36; }
    .q7 { background: #FCE4EC; color: #7B1830; }

    /* ── Candle / glow footer ── */
    .footer-glow {
      margin-top: 70px;
      text-align: center;
      opacity: 0;
      animation: rise 1s ease forwards 2.3s;
    }
    .candle {
      font-size: 3.5rem;
      animation: flicker 1.8s ease-in-out infinite alternate;
      display: inline-block;
    }
    @keyframes flicker {
      0%   { filter: drop-shadow(0 0 6px #F4A827) drop-shadow(0 0 18px #F26D5B88); transform: scaleY(1); }
      40%  { filter: drop-shadow(0 0 10px #F4A827) drop-shadow(0 0 28px #F26D5BAA); transform: scaleY(1.04) rotate(-1deg); }
      100% { filter: drop-shadow(0 0 4px #FDDFA0) drop-shadow(0 0 12px #F4A82799); transform: scaleY(0.97) rotate(0.5deg); }
    }
    .footer-text {
      font-family: 'Dancing Script', cursive;
      font-size: clamp(0.95rem, 2.5vw, 1.2rem);
      color: var(--coral);
      margin-top: 10px;
      letter-spacing: 0.04em;
    }

    /* ── Floating colour orbs ── */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(70px);
      opacity: 0.35;
      pointer-events: none;
      z-index: 0;
      animation: orbFloat ease-in-out infinite alternate;
    }
    .orb1 { width: 380px; height: 380px; background: #F4A827; top: -100px; left: -120px; animation-duration: 14s; }
    .orb2 { width: 300px; height: 300px; background: #F26D5B; bottom: 60px; right: -80px; animation-duration: 18s; animation-delay: -6s; }
    .orb3 { width: 220px; height: 220px; background: #E8607A; top: 40%; left: 65%; animation-duration: 11s; animation-delay: -3s; }
    @keyframes orbFloat {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(30px, 20px) scale(1.1); }
    }
  </style>
</head>
<body>

  <!-- Orbs -->
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>

  <!-- Animated gradient wash -->
  <div class="bg-canvas"></div>

  <!-- Floating petals layer (built by JS) -->
  <div class="petals-layer" id="petals"></div>

  <!-- Content -->
  <div class="page">

    <div class="hero">
      <p class="tag-line">✦ A message from the heart ✦</p>
      <h1 class="hero-title">Happy<br/><span class="accent">Mother's Day</span></h1>
      <p class="hero-sub">To the woman whose love has no beginning and no end —<br/>this day is yours.</p>
    </div>

    <div class="divider"></div>

    <div class="card">
      <p class="message">
        Dear Mama, <br/><br/>
        There are no words grand enough to describe the warmth you carry —
        the kind that wraps around a room the moment you walk in.
        You have given me <strong>roots to stand firm</strong> and
        <strong>wings to reach far</strong>.<br/><br/>

        Every meal made with love, every quiet sacrifice unseen, every prayer
        whispered in the dark for me — I feel it all, even when I forget
        to say so. <br/><br/>

        Today and every day, thank you for being my <strong>first home</strong>,
        my <strong>greatest teacher</strong>, and the most beautiful soul I know.
        You are irreplaceable. You are everything. <br/><br/>

        I love you more than words can hold. 🌸
      </p>
      <p class="signature">— With all my love, Fredrick Oindo 💛</p>
    </div>

    <div class="hearts-row">
      <div class="heart-bubble">💛</div>
      <div class="heart-bubble">🧡</div>
      <div class="heart-bubble">🌸</div>
      <div class="heart-bubble">❤️</div>
      <div class="heart-bubble">🌺</div>
    </div>

    <div class="qualities">
      <span class="qual-chip q1">Unconditional Love</span>
      <span class="qual-chip q2">Strength &amp; Grace</span>
      <span class="qual-chip q3">Endless Warmth</span>
      <span class="qual-chip q4">Tender Heart</span>
      <span class="qual-chip q5">Wisdom Beyond Measure</span>
      <span class="qual-chip q6">Unshakable Faith</span>
      <span class="qual-chip q7">My Greatest Gift</span>
    </div>

    <div class="footer-glow">
      <div class="candle">🕯️</div>
      <p class="footer-text">A flame of gratitude — always burning for you</p>
    </div>

  </div>

  <script>
    // ── Generate falling petals ──
    const petalLayer = document.getElementById('petals');
    const colors = ['#F4A827','#F26D5B','#E8607A','#F7C948','#F5B8A0','#F9D6CB'];

    for (let i = 0; i < 28; i++) {
      const p = document.createElement('div');
      p.className = 'petal';
      const size = 12 + Math.random() * 18;
      p.style.cssText = `
        left: ${Math.random() * 100}%;
        width: ${size}px;
        height: ${size * 1.4}px;
        background: ${colors[Math.floor(Math.random() * colors.length)]};
        animation-duration: ${7 + Math.random() * 10}s;
        animation-delay: ${-Math.random() * 14}s;
        border-radius: ${Math.random() > 0.5 ? '50% 0 50% 0' : '0 50% 0 50%'};
        opacity: 0;
      `;
      petalLayer.appendChild(p);
    }

    // ── Parallax orb on mouse move ──
    document.addEventListener('mousemove', e => {
      const mx = (e.clientX / window.innerWidth - 0.5) * 40;
      const my = (e.clientY / window.innerHeight - 0.5) * 30;
      document.querySelectorAll('.orb').forEach((o, i) => {
        const factor = (i + 1) * 0.5;
        o.style.transform = `translate(${mx * factor}px, ${my * factor}px)`;
      });
    });
  </script>
</body>
</html>
